{
    "algo_name": "diffusion_policy",
    "experiment": {
        "name": "test",
        "validate": false,
        "logging": {
            "terminal_output_to_txt": true,
            "log_tb": false,
            "log_wandb": false,
            "wandb_proj_name": "debug"
        },
        "save": {
            "enabled": true,
            "every_n_seconds": null,
            "every_n_epochs": 50,
            "epochs": [],
            "on_best_validation": true,
            "on_best_rollout_return": false,
            "on_best_rollout_success_rate": true
        },
        "epoch_every_n_steps": 50,
        "validation_epoch_every_n_steps": 100,
        "env": null,
        "additional_envs": null,
        "render": false,
        "render_video": false,
        "keep_all_videos": false,
        "video_skip": 5,
        "rollout": {
            "enabled": false,
            "n": 50,
            "horizon": 400,
            "rate": 50,
            "warmstart": 0,
            "terminate_on_success": true
        },
        "env_meta_update_dict": {
            "type": 1,
            "env_kwargs": {
                "controller_configs": {
                    "control_freq": 30
                }
            }
        }
    },
    "train": {
        "data": "robomimic/robomimic/datasets/umi_pick_place_0_5.hdf5",
        "data_human": "robomimic/robomimic/datasets/umi_pick_place_200_0.hdf5",
        "output_dir":"exps/policy_trained_models/umi_pick_place",
        "action_stats": "robomimic/robomimic/datasets/umi_pick_place_action_stats.json",
        "num_data_workers": 10,
        "hdf5_cache_mode": "all",
        "hdf5_use_swmr": true,
        "hdf5_load_next_obs": false,
        "hdf5_normalize_obs": false,
        "hdf5_filter_key": "train",
        "seq_length": 32,
        "pad_seq_length": true,
        "frame_stack": 1,
        "pad_frame_stack": true,
        "dataset_keys": [
            "action_absolute"
        ],
        "action_keys": [
            "action_absolute"
        ],
        "action_config": {
            "action_absolute": {
                "normalization": "min_max"
            }
        },
        "goal_mode": null,
        "cuda": true,
        "batch_size": 128,
        "num_epochs": 301,
        "seed": 1,
        "data_format": "robomimic",
        "interpolate": {
            "enabled": true,
            "horizon": 155,
            "mode": "nearest"
        },
        "num_human_demo": 100,
        "num_robot_demo": 5,
        "interpolate_human": {
            "enabled": true,
            "horizon": 32,
            "mode": "nearest"
        },
        "cotraining": true,
        "mapping": "robomimic/robomimic/datasets/umi_pick_place_action_mapping.json",
        "mixup": true
    },
    "algo": {
        "optim_params": {
            "policy": {
                "optimizer_type": "adamw",
                "learning_rate": {
                    "initial": 0.0001,
                    "decay_factor": 0.1,
                    "epoch_schedule": [],
                    "scheduler_type": "linear"
                },
                "regularization": {
                    "L2": 0.0
                }
            }
        },
        "horizon": {
            "observation_horizon": 2,
            "action_horizon": 32,
            "prediction_horizon": 32
        },
        "unet": {
            "enabled": true,
            "diffusion_step_embed_dim": 256,
            "down_dims": [256,512,1024],
            "kernel_size": 5,
            "n_groups": 8
        },
        "ema": {
            "enabled": false,
            "power": 0.75
        },
        "ddpm": {
            "enabled": false,
            "num_train_timesteps": 100,
            "num_inference_timesteps": 100,
            "beta_schedule": "squaredcos_cap_v2",
            "clip_sample": true,
            "prediction_type": "epsilon"
        },
        "ddim": {
            "enabled": true,
            "num_train_timesteps": 100,
            "num_inference_timesteps": 10,
            "beta_schedule": "squaredcos_cap_v2",
            "clip_sample": true,
            "set_alpha_to_one": true,
            "steps_offset": 0,
            "prediction_type": "epsilon"
        }

    },
    "observation": {
        "modalities": {
            "obs": {
                "low_dim": [
                    "eef_pose_w_gripper"
                ],
                "rgb": [
                    "agentview_image",
                    "wrist_image"
                ],
                "depth": [],
                "scan": []
            },
            "goal": {
                "low_dim": [],
                "rgb": [],
                "depth": [],
                "scan": []
            }
        },
        "encoder": {
            "low_dim": {
                "core_class": null,
                "core_kwargs": {},
                "obs_randomizer_class": null,
                "obs_randomizer_kwargs": {}
            },
            "rgb": {
                "core_class": "VisualCore",
                "core_kwargs": {
                    "feature_dimension": 64,
                    "pool_kwargs": {
                        "num_kp": 32,
                        "learnable_temperature": false,
                        "temperature": 1.0,
                        "noise_std": 0.0
                    }
                }
            },
            "depth": {
                "core_class": "VisualCore",
                "core_kwargs": {},
                "obs_randomizer_class": null,
                "obs_randomizer_kwargs": {}
            },
            "scan": {
                "core_class": "ScanCore",
                "core_kwargs": {},
                "obs_randomizer_class": null,
                "obs_randomizer_kwargs": {}
            }
        }
    }
}